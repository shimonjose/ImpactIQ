# ImpactIQ environment — COPY to `.env` and fill values locally.
# `.env` is gitignored. Never paste secret VALUES into chat; only the variable
# NAMES are discussed. ImpactIQ reads these via src/impactiq/settings.py.

# ── P0: read-only service identity (client credentials) ──────────────────────
# Structure reader: Entra app registration -> Power Platform Application User
# with a CUSTOM Organization-level Read role and NO write/create/delete.
DATAVERSE_URL=
# The solution to scope the estate analysis to (your tenant's solution display
# name). Used as the default for every analysis request and the CLI. If unset,
# falls back to the reference sample's name.
IMPACTIQ_SOLUTION=
# Optional: model-driven app id for "Open in Power Apps" links on record cards.
POWERAPPS_APP_ID=
ENTRA_TENANT_ID=
IMPACTIQ_CLIENT_ID=
IMPACTIQ_CLIENT_SECRET=

# ── P3: Azure AI Foundry project + chat model ────────────────────────────────
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT=
# P7 (optional): a separate cheaper model for the specialist agents.
FOUNDRY_SPECIALIST_DEPLOYMENT=
# Optional: high-throughput/long-context deployment for the heavy reasoning
# loops (unified agent + deep pipeline). Unset => FOUNDRY_MODEL_DEPLOYMENT.
FOUNDRY_HEAVY_MODEL_DEPLOYMENT=

# ── Builder (sandbox FIX carve-out) ──────────────────────────────────────────
# A SEPARATE sandbox environment; the builder refuses to run against
# DATAVERSE_URL. Fix-only, scoped to the dedicated solution, role-gated.
BUILD_DATAVERSE_URL=
IMPACTIQ_BUILD_SOLUTION=
IMPACTIQ_BUILDER_ROLE=ImpactIQ Builder

# ── P4: Foundry IQ knowledge base (Path B - MCP-attached KB) ────────────────
# AI Search service URL, e.g. https://my-search.search.windows.net
AISEARCH_ENDPOINT=
# Knowledge base name on the AI Search service.
FOUNDRY_KB_NAME=
# Foundry project `RemoteTool` connection name pointing at the KB MCP endpoint.
FOUNDRY_KB_CONNECTION_NAME=

# ── P5: Work IQ (delegated / on-behalf-of the signed-in user) ────────────────
# Verified 2026-06: Foundry connects to Work IQ over A2A via WorkIQPreviewTool,
# NOT the generic MCP path. A dedicated Entra app (impactiq-workiq) holds the
# delegated WorkIQAgent.Ask permission; its client id/secret live inside the
# Foundry connection, so code only needs the connection's ARM resource ID.
# The id/secret are kept here for connection rebuilds only.
IMPACTIQ_WORKIQ_CLIENT_ID=
IMPACTIQ_WORKIQ_CLIENT_SECRET=
# Full ARM resource ID: /subscriptions/<sub>/resourceGroups/<rg>/providers/
#   Microsoft.CognitiveServices/accounts/<acct>/projects/<proj>/connections/impactiq-workiq
FOUNDRY_WORKIQ_CONNECTION_ID=
# P8/P9: Work IQ MCP server connections (one per surface). Tools are
# allow-listed in agents/workiq.py (Mail=draft-only, User=read-only,
# Dataverse=records-only/no schema-or-delete, Calendar/Word/Teams=confirm-gated).
FOUNDRY_WORKIQ_MAIL_CONNECTION_ID=
FOUNDRY_WORKIQ_USER_CONNECTION_ID=
FOUNDRY_WORKIQ_DATAVERSE_CONNECTION_ID=
FOUNDRY_WORKIQ_CALENDAR_CONNECTION_ID=
FOUNDRY_WORKIQ_WORD_CONNECTION_ID=
FOUNDRY_WORKIQ_TEAMS_CONNECTION_ID=
# Dataverse environment id for the Work IQ Dataverse direct endpoint
# ({org}/api/mcp, allow-listed by calling app id).
FOUNDRY_WORKIQ_DATAVERSE_ENV_ID=

# ── Production hosting (Azure App Service bridge) ─────────────────────────────
# Shared secret guarding the bridge API. The Teams surface sends it as the
# X-ImpactIQ-Key header; set the SAME value on BOTH the bridge and surface App
# Services so only the surface can reach the API. Empty locally => guard is a
# no-op (local F5 / CLI dev unchanged).
IMPACTIQ_BRIDGE_KEY=

# ── Verification hardening (optional feature flags; all OFF/safe by default) ──
# Added with the verdict-gate / structured-output / critic work (2026-06-14).
# Each is read directly from the environment; unset = the documented default.
# Restart the bridge after changing any of these (loaded at process start).
#
# Conditional critic + adversarial write-verifier (deep pipeline). When set, a
# skeptic LLM double-checks the verdict ONLY on high-stakes/uncertain turns (a
# write artifact, a change-collision, a verdict-gate flag, or borderline
# confidence) and DEFAULT-DENIES a refuted data-write. Median turn pays nothing.
# Set to 1 to enable.
IMPACTIQ_CRITIC=
# Optional: confidence below which the critic also fires (default 0.7).
IMPACTIQ_CRITIC_CONF_FLOOR=
#
# Post-adjudication verdict gate. Unset/"shadow" = compute+log only (no change
# to the answer); "enforce" = actually drop ungrounded citations / strip
# unverified owner names / floor risk under a freeze; "off" = skip. Keep at
# shadow until the eval corpus has live cases (see evals/).
IMPACTIQ_VERDICT_GATE=
#
# Native strict JSON-schema output for the orchestrator plan (vs scraping JSON
# from prose). Set to 1 to enable; fallback parser stays as the safety net.
IMPACTIQ_STRUCTURED_OUTPUT=
