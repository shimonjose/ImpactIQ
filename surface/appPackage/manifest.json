{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.27/MicrosoftTeams.schema.json",
    "manifestVersion": "1.27",
    "version": "1.1.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Impact IQ",
        "websiteUrl": "https://github.com/shimonjose/ImpactIQ",
        "privacyUrl": "https://github.com/shimonjose/ImpactIQ/blob/main/README.md",
        "termsOfUseUrl": "https://github.com/shimonjose/ImpactIQ/blob/main/LICENSE"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Impact IQ${{APP_NAME_SUFFIX}}",
        "full": "ImpactIQ — Power Platform impact & change intelligence"
    },
    "description": {
        "short": "Impact analysis, governance grounding and live work signals for your estate.",
        "full": "ImpactIQ answers 'what breaks if...?' and 'why did this happen?' for your Power Platform estate. A deterministic dependency engine walks the impact graph, governance documents ground every verdict (Foundry IQ), and Work IQ surfaces who is affected or already discussing it. Every proposed message or data fix is draft-only until you explicitly confirm; all sends and writes are audit-logged."
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "copilotAgents": {
        "customEngineAgents": [
            {
                "type": "bot",
                "id": "${{BOT_ID}}"
            }
        ]
    },
    "bots": [
        {
            "botId": "${{BOT_ID}}",
            "scopes": [
                "copilot",
                "personal",
                "team"
            ],
            "supportsFiles": false,
            "isNotificationOnly": false,
            "commandLists": [
                {
                    "scopes": [
                        "copilot",
                        "personal"
                    ],
                    "commands": [
                        {
                            "title": "How can you help me?",
                            "description": "How can you help me?"
                        }
                    ]
                }
            ]
        }
    ],
    "composeExtensions": [],
    "configurableTabs": [],
    "staticTabs": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "token.botframework.com",
        "login.microsoftonline.com"
    ]
}